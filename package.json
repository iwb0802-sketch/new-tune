{
  "name": "sandbox-app-template",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/web && bunx vite",
    "dev:desktop": "cd packages/desktop && bunx vite",
    "dev:mobile": "cd packages/mobile && bunx expo start --port 4300",
    "build": "turbo build",
    "build:web": "cd packages/web && bunx vite build",
    "start": "pm2 startOrRestart ecosystem.config.cjs --update-env",
    "stop": "pm2 delete web-app 2>/dev/null || true",
    "kill:port": "bun run internal:kill-port",
    "lint": "bun run internal:check-conventions && oxlint . --deny-warnings --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --deny-warnings --no-error-on-unmatched-pattern",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "internal:check-conventions": "konsistent",
    "internal:kill-port": "lsof -t -i :${PORT:-4200} | xargs kill -9"
  },
  "devDependencies": {
    "@tursodatabase/api": "^1.9.2",
    "@types/bun": "1.3.14",
    "@types/semver": "^7.7.1",
    "konsistent": "^1.0.0-beta.2",
    "oxfmt": "0.54.0",
    "oxlint": "1.69.0",
    "semver": "^7.7.2",
    "turbo": "2.9.18",
    "typescript": "5.9.3",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@libsql/client": "^0.17.2",
    "cloudflare": "^5.2.0",
    "pm2": "^7.0.1"
  }
}
